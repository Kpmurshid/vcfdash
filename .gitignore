test_data/*.bam.bai
test_data/*.vcf.gz
test_data/*.vcf.gz.tbi
test_data/*.vcf
test_data/reports/
test_data/bed_file/bam/
# Large BED files (>50 MB — excluded from git)
test_data/bed_file/hg38_Twist.sorted.bed
test_data/bed_file/hg38_Twist.antitargets.bed
test_data/bed_file/hg38_Twist_Bioscience_for_Illumina_Exome_2_5.bed

